<?xml version="1.0"?>
<robot name="grasp_screw_tool_unactuated">
  <link name="base_link"/>

  <link name="grasp_screw_tool_link">
    <visual>
      <geometry>
        <mesh filename="package://grasp_screw_tool_description/meshes/collision/grasp_screw_tool_collision.stl"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://grasp_screw_tool_description/meshes/collision/grasp_screw_tool_collision.stl"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_to_tool" type="fixed">
    <parent link="base_link"/>
    <child link="grasp_screw_tool_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</robot>
