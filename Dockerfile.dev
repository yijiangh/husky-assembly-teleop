# Development Dockerfile - mounts source code instead of copying
# ROS2 Humble on Ubuntu 22.04
FROM ros:humble-ros-base-jammy

ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y \
    # Python and pip
    python3-pip \
    python3-venv \
    # tracikpy dependencies
    libeigen3-dev \
    liborocos-kdl-dev \
    libkdl-parser-dev \
    liburdfdom-dev \
    libnlopt-dev \
    libnlopt-cxx-dev \
    # Build tools
    build-essential \
    cmake \
    git \
    swig \
    # ROS2 build tools
    python3-colcon-common-extensions \
    python3-rosdep \
    # GUI support (for pybullet visualization)
    libgl1-mesa-glx \
    libgl1-mesa-dri \
    libxrender1 \
    libxext6 \
    x11-apps \
    # Required for Cursor/VSCode server
    curl \
    wget \
    ca-certificates \
    gnupg \
    lsb-release \
    openssh-client \
    procps \
    # Development tools
    vim \
    nano \
    gdb \
    && rm -rf /var/lib/apt/lists/*

# Set up workspace directory
WORKDIR /ros2_ws

# Create venv setup script (handles both fresh installs and volume mounts)
RUN echo '#!/bin/bash\n\
if [ ! -f /ros2_ws/venv/bin/activate ]; then\n\
    echo "Creating Python virtual environment..."\n\
    python3 -m venv /ros2_ws/venv --system-site-packages\n\
    source /ros2_ws/venv/bin/activate\n\
    python3 -m pip install --upgrade pip wheel\n\
    python3 -m pip install "setuptools==68.2.2" "packaging>=24.2"\n\
    python3 -m pip install "numpy<1.25.0" "kdtree==0.16" "matplotlib==3.10.3" pybullet debugpy roslibpy\n\
fi\n\
' > /ros2_ws/setup_venv.sh && chmod +x /ros2_ws/setup_venv.sh

# Create Python virtual environment (will be overwritten if volume mounted)
RUN python3 -m venv /ros2_ws/venv --system-site-packages

# Install base Python dependencies
RUN /bin/bash -c "source /ros2_ws/venv/bin/activate && \
    python3 -m pip install --upgrade pip wheel && \
    python3 -m pip install 'setuptools==68.2.2' 'packaging>=24.2' && \
    python3 -m pip install \
    'numpy<1.25.0' \
    'kdtree==0.16' \
    'matplotlib==3.10.3' \
    pybullet \
    debugpy \
    roslibpy"

# Create setup script that will be run on container start
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
# Ensure venv exists (handles volume mount case)\n\
/ros2_ws/setup_venv.sh\n\
\n\
# Activate virtual environment\n\
source /ros2_ws/venv/bin/activate\n\
source /opt/ros/humble/setup.bash\n\
\n\
# Install external dependencies if not already installed\n\
if [ -d "/ros2_ws/src/husky_assembly_teleop/external/compas_fab" ]; then\n\
    pip show compas_fab > /dev/null 2>&1 || pip install -e /ros2_ws/src/husky_assembly_teleop/external/compas_fab\n\
fi\n\
if [ -d "/ros2_ws/src/husky_assembly_teleop/external/pybullet_planning" ]; then\n\
    pip show pybullet_planning > /dev/null 2>&1 || pip install -e /ros2_ws/src/husky_assembly_teleop/external/pybullet_planning\n\
fi\n\
if [ -d "/ros2_ws/src/husky_assembly_teleop/external/tracikpy" ]; then\n\
    pip show tracikpy > /dev/null 2>&1 || pip install -e /ros2_ws/src/husky_assembly_teleop/external/tracikpy\n\
fi\n\
\n\
# Build workspace if install folder does not exist\n\
if [ ! -d "/ros2_ws/install" ]; then\n\
    echo "Building ROS2 workspace..."\n\
    cd /ros2_ws\n\
    python3 -m colcon build --symlink-install\n\
fi\n\
\n\
# Source the workspace\n\
if [ -f "/ros2_ws/install/setup.bash" ]; then\n\
    source /ros2_ws/install/setup.bash\n\
fi\n\
\n\
exec "$@"' > /ros2_ws/entrypoint.sh && chmod +x /ros2_ws/entrypoint.sh

# Create convenience aliases
RUN echo '\n\
# Convenience aliases\n\
alias cb="cd /ros2_ws && python3 -m colcon build --symlink-install"\n\
alias cbs="cd /ros2_ws && python3 -m colcon build --symlink-install --packages-select"\n\
alias src="source /ros2_ws/install/setup.bash"\n\
alias husky="ros2 run husky_assembly_teleop husky_monitor"\n\
\n\
# Auto-activate venv and source ROS2\n\
source /ros2_ws/venv/bin/activate\n\
source /opt/ros/humble/setup.bash\n\
if [ -f /ros2_ws/install/setup.bash ]; then\n\
    source /ros2_ws/install/setup.bash\n\
fi\n\
' >> /root/.bashrc

ENTRYPOINT ["/ros2_ws/entrypoint.sh"]
CMD ["bash"]
